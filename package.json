{
  "name": "sbek-automation",
  "version": "1.0.0",
  "description": "SBEK Jewelry — Operations & Marketing Automation System",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "setup:sheets": "tsx scripts/setup-sheets.ts",
    "setup:webhooks": "tsx scripts/register-webhooks.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "node-cron": "^3.0.3",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.5.0",
    "@woocommerce/woocommerce-rest-api": "^1.0.1",
    "google-spreadsheet": "^4.1.4",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "nodemailer": "^6.9.16",
    "handlebars": "^4.7.8",
    "openai": "^4.77.0",
    "@bull-board/express": "^6.5.0",
    "@bull-board/api": "^6.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^2.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/cors": "^2.8.17",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
