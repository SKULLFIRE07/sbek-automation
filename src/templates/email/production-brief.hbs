<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Production Brief</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F5F5; font-family: Arial, sans-serif;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F5F5;">
    <tr>
      <td align="center" style="padding: 24px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Gold Header -->
          <tr>
            <td align="center" style="background-color: #B8860B; padding: 28px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 36px; font-weight: bold; color: #FFFFFF; letter-spacing: 8px;">SBEK</td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 11px; color: rgba(255,255,255,0.8); letter-spacing: 3px; padding-top: 6px; text-transform: uppercase;">Production Brief</td>
                </tr>
              </table>
            </td>
          </tr>
          <tr><td style="background-color: #DAA520; height: 3px; font-size: 0; line-height: 0;">&nbsp;</td></tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; padding-bottom: 16px;">
                    New Production Assignment
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-bottom: 24px;">
                    A new order has been assigned to production. Here are the details:
                  </td>
                </tr>
              </table>

              <!-- Order Details -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FBF7F0; border-radius: 6px; border: 1px solid #F0E6D0;">
                <tr>
                  <td style="padding: 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Order ID</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; font-weight: bold; padding-bottom: 16px;">{{order_id}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Product</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; font-weight: bold; padding-bottom: 16px;">{{product_name}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Customer</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; padding-bottom: 16px;">{{customer_name}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Ring Size</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; padding-bottom: 16px;">{{ring_size}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Metal Type</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; padding-bottom: 16px;">{{metal_type}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Engraving</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333; padding-bottom: 16px;">{{engraving}}</td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px; padding-bottom: 4px;">Due Date</td>
                      </tr>
                      <tr>
                        <td style="font-family: Georgia, serif; font-size: 18px; color: #B8860B; font-weight: bold;">{{due_date}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1A1A1A; padding: 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 20px; color: #B8860B; letter-spacing: 6px;">SBEK</td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 12px; color: #777; padding-top: 8px;">Internal production notification</td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
