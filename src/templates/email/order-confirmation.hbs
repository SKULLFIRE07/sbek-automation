<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thank you for your order!</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%;">

  <!-- Outer wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F5F5;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Main container -->
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Gold Header Bar -->
          <tr>
            <td align="center" style="background-color: #B8860B; padding: 28px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 36px; font-weight: bold; color: #FFFFFF; letter-spacing: 8px;">
                    SBEK
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 11px; color: rgba(255,255,255,0.8); letter-spacing: 3px; padding-top: 6px; text-transform: uppercase;">
                    Fine Indian Jewelry
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Decorative gold line -->
          <tr>
            <td style="background-color: #DAA520; height: 3px; font-size: 0; line-height: 0;">&nbsp;</td>
          </tr>

          <!-- Body Content -->
          <tr>
            <td style="padding: 40px 32px 24px 32px;">

              <!-- Greeting -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; padding-bottom: 8px;">
                    Thank You for Your Order!
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333333; line-height: 1.6; padding-bottom: 24px;">
                    Dear {{customer_name}},
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-bottom: 32px;">
                    Thank you for choosing SBEK. Your order has been received and we are delighted to begin this journey with you. Every piece from our collection is a testament to India's rich jewelry-making heritage, and we can't wait for you to experience it firsthand.
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-bottom: 2px solid #F0E6D0; padding-bottom: 0; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Order Summary Heading -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 20px; color: #B8860B; padding: 28px 0 16px 0;">
                    Order Summary
                  </td>
                </tr>
              </table>

              <!-- Order Summary Table -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border: 1px solid #F0E6D0; border-radius: 6px; overflow: hidden;">
                <tr>
                  <td style="background-color: #FBF7F0; padding: 14px 20px; font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #F0E6D0; width: 40%;">
                    Order ID
                  </td>
                  <td style="background-color: #FBF7F0; padding: 14px 20px; font-family: Arial, sans-serif; font-size: 16px; color: #333333; font-weight: bold; border-bottom: 1px solid #F0E6D0;">
                    {{order_id}}
                  </td>
                </tr>
                <tr>
                  <td style="padding: 14px 20px; font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #F0E6D0;">
                    Product
                  </td>
                  <td style="padding: 14px 20px; font-family: Arial, sans-serif; font-size: 16px; color: #333333; border-bottom: 1px solid #F0E6D0;">
                    {{product_name}}
                  </td>
                </tr>
                <tr>
                  <td style="background-color: #FBF7F0; padding: 14px 20px; font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #F0E6D0;">
                    Amount
                  </td>
                  <td style="background-color: #FBF7F0; padding: 14px 20px; font-family: Arial, sans-serif; font-size: 16px; color: #333333; font-weight: bold; border-bottom: 1px solid #F0E6D0;">
                    {{amount}}
                  </td>
                </tr>
                <tr>
                  <td style="padding: 14px 20px; font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px;">
                    Order Date
                  </td>
                  <td style="padding: 14px 20px; font-family: Arial, sans-serif; font-size: 16px; color: #333333;">
                    {{order_date}}
                  </td>
                </tr>
              </table>

              <!-- Estimated Delivery -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding: 28px 0 8px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FBF7F0; border-left: 4px solid #B8860B; border-radius: 4px;">
                      <tr>
                        <td style="padding: 18px 24px;">
                          <span style="font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px;">Estimated Delivery</span><br />
                          <span style="font-family: Georgia, serif; font-size: 18px; color: #333333; font-weight: bold;">{{delivery_date}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding: 32px 0;">
                    <a href="{{tracking_url}}" target="_blank" style="display: inline-block; background-color: #B8860B; color: #FFFFFF; font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none; padding: 14px 32px; border-radius: 6px; letter-spacing: 1px;">
                      Track Your Order
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-bottom: 2px solid #F0E6D0; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Contact Support -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding: 28px 0 8px 0;">
                    <span style="font-family: Georgia, serif; font-size: 18px; color: #B8860B;">Need Help?</span>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7;">
                    Our team is here for you. Reach out to us anytime on WhatsApp at <a href="https://wa.me/91XXXXXXXXXX" style="color: #B8860B; text-decoration: underline;">+91-XXXX-XXXXXX</a> or email us at <a href="mailto:support@sbek.in" style="color: #B8860B; text-decoration: underline;">support@sbek.in</a>.
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1A1A1A; padding: 32px 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <!-- Brand -->
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; letter-spacing: 6px; padding-bottom: 16px;">
                    SBEK
                  </td>
                </tr>
                <!-- Contact Info -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 13px; color: #999999; line-height: 1.8; padding-bottom: 16px;">
                    123 Jewelry Lane, Mumbai, Maharashtra, India<br />
                    Phone: +91-XXXX-XXXXXX &nbsp;|&nbsp; Email: support@sbek.in
                  </td>
                </tr>
                <!-- Social Links -->
                <tr>
                  <td align="center" style="padding-bottom: 20px;">
                    <a href="{{instagram_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Instagram</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{facebook_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Facebook</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{pinterest_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Pinterest</a>
                  </td>
                </tr>
                <!-- Divider -->
                <tr>
                  <td style="border-bottom: 1px solid #333333; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
                <!-- Unsubscribe -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 12px; color: #777777; padding-top: 16px;">
                    You received this email because you placed an order with SBEK.<br />
                    <a href="{{unsubscribe_url}}" style="color: #999999; text-decoration: underline;">Unsubscribe</a> from future emails.
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- End Main Container -->

      </td>
    </tr>
  </table>
  <!-- End Outer Wrapper -->

</body>
</html>
