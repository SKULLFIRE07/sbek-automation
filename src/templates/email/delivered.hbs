<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SBEK Delivery Confirmation</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F0E8; font-family: Georgia, 'Times New Roman', serif; -webkit-text-size-adjust: 100%;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F0E8;">
    <tr>
      <td align="center" style="padding: 32px 16px;">

        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; box-shadow: 0 2px 20px rgba(0,0,0,0.06); border-radius: 2px;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding: 48px 40px 12px 40px; background-color: #FFFFFF;">
              <span style="font-family: Georgia, serif; font-size: 32px; font-weight: bold; color: #C9A96E; letter-spacing: 10px;">SBEK</span>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding: 0 40px 40px 40px; background-color: #FFFFFF;">
              <span style="font-family: Arial, sans-serif; font-size: 9px; color: #999999; letter-spacing: 4px; text-transform: uppercase;">The Forge</span>
            </td>
          </tr>

          <!-- Gold line -->
          <tr>
            <td style="padding: 0 48px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="border-bottom: 1px solid #C9A96E; height: 1px; font-size: 0;">&nbsp;</td></tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px 48px 40px 48px; background-color: #FFFFFF;">

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 15px; color: #333333; line-height: 1.9; padding-bottom: 28px;">
                    Your pendant has now reached you.
                  </td>
                </tr>
              </table>

              <!-- Order Details Box -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 28px;">
                <tr>
                  <td style="background-color: #FBF7F0; border-left: 3px solid #C9A96E; padding: 20px 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 11px; color: #999999; letter-spacing: 2px; text-transform: uppercase; padding-bottom: 8px;">Order Details</td>
                      </tr>
                      <tr>
                        <td style="font-family: Georgia, serif; font-size: 14px; color: #4A4A4A; line-height: 1.8;">
                          Order #{{order_id}}<br />
                          {{product_name}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 15px; color: #4A4A4A; line-height: 1.9; padding-bottom: 28px;">
                    The piece created within the SBEK forge is now in your hands.<br />
                    What it represents from this moment onward will be shaped by how you carry it.
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 15px; color: #4A4A4A; line-height: 1.9; padding-bottom: 28px;">
                    If you choose to share your pendant, tag @sab.ek.official so ARKA can see where his creations travel.
                  </td>
                </tr>
              </table>

              <!-- Stars -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding: 20px 0 36px 0; font-family: Georgia, serif; font-size: 16px; color: #C9A96E; letter-spacing: 12px;">
                    &#10022; &#10022; &#10022;
                  </td>
                </tr>
              </table>

              <!-- CTAs -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 11px; color: #999999; letter-spacing: 2px; text-transform: uppercase; padding-bottom: 20px;">
                    Continue the journey with ARKA
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 14px; padding-bottom: 10px;">
                    <span style="color: #999999; font-size: 12px;">Follow ARKA's journey</span><br />
                    <a href="https://www.instagram.com/sab.ek.official" style="color: #C9A96E; text-decoration: none;">instagram.com/sab.ek.official</a>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 14px; padding-bottom: 10px;">
                    <span style="color: #999999; font-size: 12px;">Explore more creations from the SBEK forge</span><br />
                    <a href="https://sb-ek.com" style="color: #C9A96E; text-decoration: none;">sb-ek.com</a>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 14px; padding-bottom: 0;">
                    <span style="color: #999999; font-size: 12px;">If you wish to send a message to the forge</span><br />
                    <a href="https://wa.me/918425840173" style="color: #C9A96E; text-decoration: none;">+91 84258 40173</a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer line -->
          <tr>
            <td style="padding: 0 48px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="border-bottom: 1px solid #E8DFD0; height: 1px; font-size: 0;">&nbsp;</td></tr>
              </table>
            </td>
          </tr>

          <!-- Tagline -->
          <tr>
            <td align="center" style="padding: 32px 40px 40px 40px;">
              <span style="font-family: Arial, sans-serif; font-size: 8px; color: #999999; letter-spacing: 3px; text-transform: uppercase;">ARKA KI ROSHNI, SAB KI SEVA, JEWELRY MADE FOR INDIA</span>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
