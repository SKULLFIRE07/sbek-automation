<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your piece is being crafted</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%;">

  <!-- Outer wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F5F5;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Main container -->
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Gold Header Bar -->
          <tr>
            <td align="center" style="background-color: #B8860B; padding: 28px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 36px; font-weight: bold; color: #FFFFFF; letter-spacing: 8px;">
                    SBEK
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 11px; color: rgba(255,255,255,0.8); letter-spacing: 3px; padding-top: 6px; text-transform: uppercase;">
                    Fine Indian Jewelry
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Decorative gold line -->
          <tr>
            <td style="background-color: #DAA520; height: 3px; font-size: 0; line-height: 0;">&nbsp;</td>
          </tr>

          <!-- Body Content -->
          <tr>
            <td style="padding: 40px 32px 24px 32px;">

              <!-- Greeting & Main Message -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; padding-bottom: 8px;">
                    Your Piece Is Being Crafted
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333333; line-height: 1.6; padding-bottom: 24px;">
                    Dear {{customer_name}},
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-bottom: 16px;">
                    Your handcrafted jewelry piece is now in the hands of our skilled artisans. We wanted to share this special moment with you -- the creation of your <strong style="color: #333333;">{{product_name}}</strong> has officially begun.
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 17px; font-style: italic; color: #B8860B; line-height: 1.7; padding: 16px 24px; background-color: #FBF7F0; border-radius: 6px; text-align: center;">
                    "Every SBEK piece is made with love and precision."
                  </td>
                </tr>
              </table>

              <!-- Order Reference -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding: 28px 0 8px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FBF7F0; border-left: 4px solid #B8860B; border-radius: 4px;">
                      <tr>
                        <td style="padding: 18px 24px;">
                          <span style="font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px;">Order Reference</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #333333;">{{order_id}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-bottom: 2px solid #F0E6D0; padding-top: 24px; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- What to Expect Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 20px; color: #B8860B; padding: 28px 0 20px 0;">
                    What to Expect
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-bottom: 24px;">
                    Your piece will go through our meticulous crafting process. Here is a glimpse of the journey ahead:
                  </td>
                </tr>
              </table>

              <!-- Timeline Steps -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">

                <!-- Step 1: Casting -->
                <tr>
                  <td style="padding-bottom: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="48" valign="top" style="padding-right: 16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width: 48px; height: 48px; background-color: #B8860B; border-radius: 50%; font-family: Arial, sans-serif; font-size: 18px; font-weight: bold; color: #FFFFFF; line-height: 48px;">
                                1
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <span style="font-family: Georgia, serif; font-size: 17px; color: #333333; font-weight: bold;">Casting</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #777777; line-height: 1.6;">Your piece begins to take shape as molten metal is carefully poured into the mold.</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Step 2: Stone Setting -->
                <tr>
                  <td style="padding-bottom: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="48" valign="top" style="padding-right: 16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width: 48px; height: 48px; background-color: #B8860B; border-radius: 50%; font-family: Arial, sans-serif; font-size: 18px; font-weight: bold; color: #FFFFFF; line-height: 48px;">
                                2
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <span style="font-family: Georgia, serif; font-size: 17px; color: #333333; font-weight: bold;">Stone Setting</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #777777; line-height: 1.6;">Each gem and stone is hand-set with exacting precision by our master craftsmen.</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Step 3: Polishing -->
                <tr>
                  <td style="padding-bottom: 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="48" valign="top" style="padding-right: 16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width: 48px; height: 48px; background-color: #B8860B; border-radius: 50%; font-family: Arial, sans-serif; font-size: 18px; font-weight: bold; color: #FFFFFF; line-height: 48px;">
                                3
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <span style="font-family: Georgia, serif; font-size: 17px; color: #333333; font-weight: bold;">Polishing</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #777777; line-height: 1.6;">Multiple rounds of polishing bring out the brilliant shine and luster of your piece.</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Step 4: Quality Control -->
                <tr>
                  <td style="padding-bottom: 8px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td width="48" valign="top" style="padding-right: 16px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="width: 48px; height: 48px; background-color: #B8860B; border-radius: 50%; font-family: Arial, sans-serif; font-size: 18px; font-weight: bold; color: #FFFFFF; line-height: 48px;">
                                4
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <span style="font-family: Georgia, serif; font-size: 17px; color: #333333; font-weight: bold;">Quality Control</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #777777; line-height: 1.6;">A rigorous inspection ensures every detail meets the SBEK standard of excellence.</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

              </table>

              <!-- Closing Message -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding-top: 28px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="border-bottom: 2px solid #F0E6D0; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-top: 28px;">
                    We will keep you updated as your piece progresses through each stage. In the meantime, know that your jewelry is receiving the utmost care and attention from our artisans.
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-top: 20px; padding-bottom: 8px;">
                    With warm regards,<br />
                    <strong style="color: #B8860B;">The SBEK Team</strong>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1A1A1A; padding: 32px 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <!-- Brand -->
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; letter-spacing: 6px; padding-bottom: 16px;">
                    SBEK
                  </td>
                </tr>
                <!-- Contact Info -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 13px; color: #999999; line-height: 1.8; padding-bottom: 16px;">
                    Phone: {{support_phone}} &nbsp;|&nbsp; Email: {{support_email}}
                  </td>
                </tr>
                <!-- Social Links -->
                <tr>
                  <td align="center" style="padding-bottom: 20px;">
                    <a href="{{instagram_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Instagram</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{facebook_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Facebook</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{pinterest_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Pinterest</a>
                  </td>
                </tr>
                <!-- Divider -->
                <tr>
                  <td style="border-bottom: 1px solid #333333; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
                <!-- Unsubscribe -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 12px; color: #777777; padding-top: 16px;">
                    You received this email because you placed an order with SBEK.<br />
                    <a href="{{unsubscribe_url}}" style="color: #999999; text-decoration: underline;">Unsubscribe</a> from future emails.
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- End Main Container -->

      </td>
    </tr>
  </table>
  <!-- End Outer Wrapper -->

</body>
</html>
