<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QC Failed - Rework Needed</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F5F5; font-family: Arial, sans-serif;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F5F5;">
    <tr>
      <td align="center" style="padding: 24px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Red Header -->
          <tr>
            <td align="center" style="background-color: #CC3333; padding: 28px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 36px; font-weight: bold; color: #FFFFFF; letter-spacing: 8px;">SBEK</td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 11px; color: rgba(255,255,255,0.8); letter-spacing: 3px; padding-top: 6px; text-transform: uppercase;">QC Alert</td>
                </tr>
              </table>
            </td>
          </tr>
          <tr><td style="background-color: #AA2222; height: 3px; font-size: 0; line-height: 0;">&nbsp;</td></tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding-bottom: 24px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="width: 72px; height: 72px; background-color: #FFF0F0; border: 3px solid #CC3333; border-radius: 50%; font-size: 36px; line-height: 72px; color: #CC3333;">
                          &#10007;
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 24px; color: #CC3333; padding-bottom: 16px;">
                    QC Failed - Rework Required
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555; line-height: 1.7; padding-bottom: 24px;">
                    Quality check has failed for the following order. Immediate rework is required.
                  </td>
                </tr>
              </table>

              <!-- Order Details -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FFF5F5; border-left: 4px solid #CC3333; border-radius: 4px;">
                <tr>
                  <td style="padding: 18px 24px;">
                    <span style="font-family: Arial, sans-serif; font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: 1px;">Order ID</span><br />
                    <span style="font-family: Arial, sans-serif; font-size: 16px; color: #333; font-weight: bold;">{{order_id}}</span>
                  </td>
                </tr>
              </table>

              <!-- Failed Items -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 20px; color: #CC3333; padding: 28px 0 16px 0;">
                    Failed Checks
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555; line-height: 1.7; padding-bottom: 24px; background-color: #FFF5F5; padding: 18px 24px; border-radius: 6px;">
                    {{failed_items}}
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555; line-height: 1.7; padding-top: 24px;">
                    The order has been moved back to "In Production" for rework. Please address the failed items and re-submit for QC.
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1A1A1A; padding: 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 20px; color: #B8860B; letter-spacing: 6px;">SBEK</td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 12px; color: #777; padding-top: 8px;">Internal QC alert notification</td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
